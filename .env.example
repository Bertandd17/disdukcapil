# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="Disdukcapil Toba"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://disdukcapil-toba.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# =============================================================================
# LOGGING
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# DATABASE
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u771257746_disdukcapil
DB_USERNAME=u771257746_disdukcapil
DB_PASSWORD=Eduward@12345

# =============================================================================
# SESSION
# =============================================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================================================
# BROADCASTING / FILESYSTEM / QUEUE
# =============================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# =============================================================================
# CACHE
# =============================================================================
CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# =============================================================================
# REDIS
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# MAIL
# =============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@disdukcapil-toba.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# AWS (unused — placeholder)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# VITE
# =============================================================================
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# SECURITY
# =============================================================================
CSP_ENABLED=false
CSP_REPORT_ONLY=false

# =============================================================================
# OCR — EasyOCR (Primary: Railway-hosted Python OCR service)
# =============================================================================
EASYOCR_MOCK_ENABLED=false
EASYOCR_USE_API=true
EASYOCR_API_URL=https://ocr-production-b86a.up.railway.app
EASYOCR_API_HOST=0.0.0.0
EASYOCR_API_PORT=5000
EASYOCR_API_HEALTH_CHECK=true
EASYOCR_API_HEALTH_TIMEOUT=15
EASYOCR_CLI_ENABLED=false
EASYOCR_PYTHON_PATH=python
EASYOCR_TIMEOUT=60
EASYOCR_USE_GPU=false

# =============================================================================
# OCR — OCR.space (Fallback 1: free tier 25k req/month)
# =============================================================================
OCR_SPACE_ENABLED=true
OCR_SPACE_API_KEY=K85123795988957
OCR_SPACE_ENDPOINT=https://api.ocr.space/parse/image
OCR_SPACE_LANGUAGE=auto
OCR_SPACE_ENGINE=2
OCR_SPACE_TIMEOUT=60
OCR_SPACE_MAX_FILE_SIZE=1200000
OCR_SPACE_MAX_DIMENSION=1280

# =============================================================================
# OCR — Google Cloud Vision (Fallback 2: mock enabled)
# =============================================================================
GCP_MOCK_ENABLED=true
GCP_MOCK_DELAY_SECONDS=2
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_CREDENTIALS_PATH=
GOOGLE_VISION_TIMEOUT=30

# =============================================================================
# OCR — Local file-based mock (Fallback 3)
# =============================================================================
GCP_MOCK_DATASET_DIR=/home/u286131991/domains/disdukcapil-toba.com/public_html/scripts/models/mock_ktp

###############################################################################
# Railway OCR Service Environment
# Service:  ocr-disdukcapil-production (Python + EasyOCR/CRNN)
# Image:    railway/ocr.Dockerfile
# Owner:    tim PA3 Disdukcapil Toba
###############################################################################

# ===== Server =====
PORT=5000
HOST=0.0.0.0
PYTHONUNBUFFERED=1
KMP_DUPLICATE_LIB_OK=TRUE

# ===== Runtime behavior =====
KTP_CRNN_ENABLED=true
EASYOCR_DOWNLOAD_ENABLED=false
EASYOCR_LANGS=id,en

# ===== Model paths =====
EASYOCR_MODEL_DIR=/app/scripts/models/easyocr_models
KTP_CRNN_STATE_DICT_PATH=/app/scripts/models/ktp_crnn_v2_state_dict.pt
KTP_CRNN_TRACED_PATH=/app/scripts/models/ktp_crnn_v2_traced.pt
EASYOCR_DETECTOR_MODEL_PATH=/app/scripts/models/easyocr_models/craft_mlt_25k.pth
EASYOCR_RECOGNIZER_MODEL_PATH=/app/scripts/models/easyocr_models/latin_g2.pth

# ===== Health / diagnostics =====
HEALTHCHECK_PATH=/health
HEALTHCHECK_TIMEOUT=10

# ===== Upload limits =====
MAX_UPLOAD_MB=16